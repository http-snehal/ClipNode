<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ClipNode - Code Sharing</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* A tiny bit of custom CSS to ensure Monaco fills the remaining space perfectly */
        #editor-container { height: calc(100vh - 64px); } 
        
        /* Hide the default scrollbar for a cleaner look */
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #1e1e1e; }
        ::-webkit-scrollbar-thumb { background: #424242; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #4f4f4f; }
    </style>
</head>
<body class="bg-[#1e1e1e] text-gray-200 overflow-hidden flex flex-col h-screen">

    <header class="h-16 bg-[#252526] border-b border-[#333333] flex items-center justify-between px-6 shadow-sm">
        
        <div class="flex items-center gap-6">
            <h1 class="text-xl font-bold tracking-tight text-gray-100 flex items-center gap-2">
                <svg class="w-6 h-6 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path></svg>
                ClipNode
            </h1>

            <div class="flex items-center gap-3">
                <select id="language-select" class="bg-[#1e1e1e] border border-[#3c3c3c] text-sm text-gray-300 rounded px-3 py-1.5 focus:outline-none focus:border-blue-500 transition-colors cursor-pointer">
                    <option value="javascript">JavaScript</option>
                    <option value="python">Python</option>
                    <option value="cpp">C++</option>
                    <option value="html">HTML</option>
                    <option value="css">CSS</option>
                    <option value="plaintext">Plain Text</option>
                </select>
            </div>
        </div>

        <button id="save-btn" class="bg-blue-600 hover:bg-blue-500 transition-colors text-white text-sm font-medium px-5 py-2 rounded shadow-md flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4l-3 3m0 0l-3-3m3 3V4"></path></svg>
            Create Paste
        </button>

    </header>

    <div id="editor-container" class="w-full"></div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.39.0/min/vs/loader.min.js"></script>
    <script>
        require.config({ paths: { 'vs': 'https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.39.0/min/vs' }});

        require(['vs/editor/editor.main'], function() {
            
            // 1. Initialize the Editor
            window.editor = monaco.editor.create(document.getElementById('editor-container'), {
                value: '// Paste your code or text here...',
                language: 'javascript', // Default
                theme: 'vs-dark',
                automaticLayout: true,
                minimap: { enabled: false },
                fontSize: 14,
                fontFamily: "'Fira Code', 'JetBrains Mono', 'Courier New', monospace",
                padding: { top: 16 }
            });

            // 2. Listen for Language Dropdown Changes
            document.getElementById('language-select').addEventListener('change', (e) => {
                const newLang = e.target.value;
                monaco.editor.setModelLanguage(window.editor.getModel(), newLang);
            });
        });

        // 3. Handle the Save Button Click
        document.getElementById('save-btn').addEventListener('click', async () => {
            const content = window.editor.getValue();
            const language = document.getElementById('language-select').value; // Grab the selected language!

            // Basic frontend validation
            if (!content || content.trim() === '// Paste your code or text here...') {
                alert("Please enter some code before saving!");
                return;
            }

            try {
                // Notice we are now sending both content AND language to the backend
                const response = await fetch('/api/paste', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        content: content,
                        language: language 
                    })
                });

                const data = await response.json();
                
                if (response.ok) {
                    window.location.href = `/${data.shortId}`;
                } else {
                    alert('Error: ' + data.error);
                }
            } catch (error) {
                console.error(error);
                alert('Failed to connect to server.');
            }
        });
    </script>
</body>
</html>